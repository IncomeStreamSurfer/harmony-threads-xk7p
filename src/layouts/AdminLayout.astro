---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;

const navItems = [
  { href: '/admin', label: '⬡ Dashboard' },
  { href: '/admin/products', label: '👕 Products' },
  { href: '/admin/orders', label: '📦 Orders' },
  { href: '/admin/messages', label: '✉️ Messages' },
  { href: '/admin/subscribers', label: '📧 Subscribers' },
  { href: '/admin/categories', label: '🗂️ Categories' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Harmony Admin</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body style="font-family:'Manrope',system-ui,sans-serif; background:#0F0F0F; color:#F0EDE8; margin:0; min-height:100vh; display:flex;">

  <!-- Sidebar -->
  <aside style="width:220px; flex-shrink:0; background:#1A1A1A; border-right:1px solid rgba(255,255,255,0.08); padding:24px 0; position:sticky; top:0; height:100vh; overflow-y:auto;">
    <a href="/" style="display:flex; align-items:center; gap:8px; padding:0 20px 24px; text-decoration:none; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom:16px;">
      <svg width="20" height="20" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="13" stroke="#C8A96E" stroke-width="1.5"/><text x="14" y="19" text-anchor="middle" fill="#C8A96E" font-size="14" font-family="Georgia,serif" font-weight="700">H</text></svg>
      <span style="font-size:13px; font-weight:600; color:#F0EDE8;">Harmony Admin</span>
    </a>
    <nav style="padding:0 12px;">
      {navItems.map(item => (
        <a href={item.href} style="display:block; padding:8px 12px; font-size:13px; color:#9A9189; text-decoration:none; border-radius:4px; margin-bottom:2px; transition:all 0.15s;"
          onmouseover="this.style.background='rgba(200,169,110,0.08)';this.style.color='#F0EDE8'"
          onmouseout="this.style.background='';this.style.color='#9A9189'">
          {item.label}
        </a>
      ))}
    </nav>
    <div style="padding:16px 20px; margin-top:auto; position:absolute; bottom:0; left:0; right:0; border-top:1px solid rgba(255,255,255,0.08);">
      <a href="/" style="font-size:12px; color:#9A9189; text-decoration:none;">← View site</a>
    </div>
  </aside>

  <!-- Main content -->
  <main style="flex:1; padding:32px; overflow-y:auto; max-height:100vh;">
    <h1 style="font-size:1.5rem; font-weight:600; margin:0 0 24px; color:#F0EDE8;">{title}</h1>
    <slot />
  </main>

</body>
</html>
