---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';
import { safeHtml } from '../../lib/sanitize';

const { slug } = Astro.params;
const sb = anonClient();

let product: any = null;
if (sb && slug) {
  const { data } = await sb
    .from('products')
    .select('*')
    .eq('slug', slug)
    .maybeSingle();
  product = data;
}

if (!product) {
  return Astro.redirect('/shop');
}

const price = `$${(product.price_pence / 100).toFixed(2)}`;
const compareAt = product.compare_at_pence ? `$${(product.compare_at_pence / 100).toFixed(2)}` : null;
const variants = product.variants ?? [];
const sizes = [...new Set(variants.map((v: any) => v.size).filter(Boolean))];
const colors = [...new Set(variants.map((v: any) => v.color).filter(Boolean))];
const isDigital = product.product_type === 'Digital book';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmony-threads-xk7p.vercel.app';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "image": product.image_url,
  "sku": product.sku,
  "brand": { "@type": "Brand", "name": product.vendor || "Harmony Threads" },
  "offers": {
    "@type": "Offer",
    "price": (product.price_pence / 100).toFixed(2),
    "priceCurrency": product.currency || "USD",
    "availability": (product.inventory ?? 0) > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    "url": `${siteUrl}/product/${slug}`
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Shop", "item": `${siteUrl}/shop` },
    { "@type": "ListItem", "position": 3, "name": product.name, "item": `${siteUrl}/product/${slug}` }
  ]
};
---

<Base
  title={product.meta_title || `${product.name} | Harmony Threads`}
  description={product.meta_description || product.description?.slice(0, 160)}
  ogImage={product.image_url}
  ogType="product"
  structuredData={[productSchema, breadcrumb]}
  tags={product.tags}
>
  <div class="pt-28 pb-20 max-w-7xl mx-auto px-6">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-muted mb-10" style="font-family:'Manrope',system-ui,sans-serif;">
      <a href="/" class="hover:text-cream transition-colors">Home</a>
      <span>/</span>
      <a href="/shop" class="hover:text-cream transition-colors">Shop</a>
      <span>/</span>
      <span class="text-cream">{product.name}</span>
    </nav>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Product image -->
      <div class="sticky top-24">
        <div class="aspect-square bg-charcoal-2 rounded-sm overflow-hidden">
          {product.image_url ? (
            <img
              src={product.image_url}
              alt={`${product.name} — Harmony Threads`}
              class="w-full h-full object-cover"
              loading="eager"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-8xl">🎵</div>
          )}
        </div>
      </div>

      <!-- Product details -->
      <div>
        {product.vendor && (
          <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3" style="font-family:'Manrope',system-ui,sans-serif;">{product.vendor}</p>
        )}

        <h1 class="text-4xl font-semibold text-cream leading-tight mb-4" style="font-family:'Playfair Display',Georgia,serif;">
          {product.name}
        </h1>

        <div class="flex items-center gap-3 mb-8">
          <span class="text-2xl font-semibold text-cream" style="font-family:'Manrope',system-ui,sans-serif;">{price}</span>
          {compareAt && (
            <span class="text-muted line-through" style="font-family:'Manrope',system-ui,sans-serif;">{compareAt}</span>
          )}
          {compareAt && (
            <span class="bg-gold/20 text-gold text-xs px-2 py-1 rounded border border-gold/30" style="font-family:'Manrope',system-ui,sans-serif;">
              Save {Math.round((1 - product.price_pence / product.compare_at_pence) * 100)}%
            </span>
          )}
        </div>

        <!-- Size selector (physical) -->
        {sizes.length > 0 && !isDigital && (
          <div class="mb-6">
            <p class="text-sm font-medium text-cream mb-3" style="font-family:'Manrope',system-ui,sans-serif;">Size</p>
            <div class="flex flex-wrap gap-2" id="size-selector">
              {sizes.map((s: string) => (
                <button
                  data-size={s}
                  class="size-btn px-4 py-2 border border-white/20 text-sm text-muted hover:border-gold hover:text-cream transition-colors rounded-sm"
                  style="font-family:'Manrope',system-ui,sans-serif;">
                  {s}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Color selector (physical) -->
        {colors.length > 0 && !isDigital && (
          <div class="mb-6">
            <p class="text-sm font-medium text-cream mb-3" style="font-family:'Manrope',system-ui,sans-serif;">Color</p>
            <div class="flex flex-wrap gap-2" id="color-selector">
              {colors.map((c: string) => (
                <button
                  data-color={c}
                  class="color-btn px-4 py-2 border border-white/20 text-sm text-muted hover:border-gold hover:text-cream transition-colors rounded-sm capitalize"
                  style="font-family:'Manrope',system-ui,sans-serif;">
                  {c}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Format selector (digital) -->
        {isDigital && (
          <div class="mb-6">
            <p class="text-sm font-medium text-cream mb-3" style="font-family:'Manrope',system-ui,sans-serif;">Format — all included</p>
            <div class="flex flex-wrap gap-2">
              {variants.map((v: any) => (
                <span class="px-3 py-1.5 border border-gold/40 text-gold text-xs rounded-full" style="font-family:'Manrope',system-ui,sans-serif;">{v.format}</span>
              ))}
            </div>
            <p class="text-xs text-muted mt-2" style="font-family:'Manrope',system-ui,sans-serif;">One purchase gives you access to all formats.</p>
          </div>
        )}

        <!-- Add to cart -->
        <button
          id="add-to-cart-btn"
          data-product-id={product.id}
          data-product-name={product.name}
          data-product-price={product.price_pence}
          data-product-image={product.image_url}
          class="w-full bg-gold text-charcoal font-semibold py-4 rounded-sm hover:bg-gold-light transition-colors text-sm mb-4"
          style="font-family:'Manrope',system-ui,sans-serif;">
          {isDigital ? 'Buy instantly — ' + price : 'Add to cart'}
        </button>

        {isDigital && (
          <p class="text-xs text-center text-muted mb-6" style="font-family:'Manrope',system-ui,sans-serif;">
            Instant download link sent to your email after purchase
          </p>
        )}

        <!-- Trust signals -->
        <div class="border-t border-white/10 pt-6 mt-2 space-y-3">
          {[
            isDigital ? '⚡ Instant delivery to your inbox' : '📦 Ships within 2 business days',
            isDigital ? '♾️ No DRM — yours to keep forever' : '🔄 Free returns within 30 days',
            '🔒 Secure checkout via Stripe',
          ].map(t => (
            <div class="flex items-center gap-2 text-sm text-muted" style="font-family:'Manrope',system-ui,sans-serif;">
              <span>{t}</span>
            </div>
          ))}
        </div>

        <!-- Description -->
        {product.body_html && (
          <div class="mt-10 pt-10 border-t border-white/10">
            <h2 class="text-lg font-semibold text-cream mb-4" style="font-family:'Playfair Display',Georgia,serif;">About this product</h2>
            <div class="prose-sm text-muted leading-relaxed space-y-3 [&_h2]:text-cream [&_h2]:font-semibold [&_h2]:mt-4 [&_strong]:text-cream [&_ul]:list-disc [&_ul]:pl-4 [&_li]:mb-1"
              style="font-family:'Manrope',system-ui,sans-serif;"
              set:html={safeHtml(product.body_html)} />
          </div>
        )}

        <!-- Internal links -->
        <div class="mt-10 pt-6 border-t border-white/10">
          <p class="text-xs text-muted mb-3" style="font-family:'Manrope',system-ui,sans-serif;">You might also like</p>
          <div class="flex flex-wrap gap-3">
            <a href="/shop" class="text-sm text-gold hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">Browse all products →</a>
            {!isDigital && <a href="/collections/graphic-tees" class="text-sm text-gold hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">More graphic tees →</a>}
            {isDigital && <a href="/collections/digital-downloads" class="text-sm text-gold hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">More digital downloads →</a>}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Variant selection
    let selectedSize = '';
    let selectedColor = '';

    document.querySelectorAll('.size-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.size-btn').forEach(b => {
          b.classList.remove('border-gold', 'text-cream');
          b.classList.add('border-white/20', 'text-muted');
        });
        btn.classList.add('border-gold', 'text-cream');
        btn.classList.remove('border-white/20', 'text-muted');
        selectedSize = (btn as HTMLElement).dataset.size ?? '';
      });
    });

    document.querySelectorAll('.color-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.color-btn').forEach(b => {
          b.classList.remove('border-gold', 'text-cream');
          b.classList.add('border-white/20', 'text-muted');
        });
        btn.classList.add('border-gold', 'text-cream');
        btn.classList.remove('border-white/20', 'text-muted');
        selectedColor = (btn as HTMLElement).dataset.color ?? '';
      });
    });

    // Add to cart
    const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;
    btn?.addEventListener('click', async () => {
      const productId = btn.dataset.productId!;
      const productName = btn.dataset.productName!;
      const productPrice = Number(btn.dataset.productPrice);
      const productImage = btn.dataset.productImage ?? '';

      const variantSku = [selectedSize, selectedColor].filter(Boolean).join('-') || undefined;

      // Direct checkout for digital, add-to-cart for physical
      const isDigital = document.querySelector('.color-btn') === null && document.querySelector('.size-btn') === null;

      if (isDigital) {
        btn.textContent = 'Redirecting to checkout…';
        btn.disabled = true;
        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ product_id: productId, qty: 1 }] }),
          });
          const { url, error } = await res.json();
          if (url) window.location.href = url;
          else alert(error ?? 'Checkout failed');
        } catch {
          btn.textContent = 'Add to cart';
          btn.disabled = false;
        }
      } else {
        // Add to localStorage cart
        const cartRaw = localStorage.getItem('ht_cart') ?? '[]';
        const cart = JSON.parse(cartRaw);
        const existing = cart.find((i: any) => i.product_id === productId && i.variant_sku === variantSku);
        if (existing) {
          existing.qty += 1;
        } else {
          cart.push({ product_id: productId, qty: 1, variant_sku: variantSku, name: productName, price: productPrice, image: productImage });
        }
        localStorage.setItem('ht_cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart:updated'));

        const orig = btn.textContent;
        btn.textContent = '✓ Added to cart';
        btn.classList.replace('bg-gold', 'bg-green-700');
        setTimeout(() => {
          btn.textContent = orig;
          btn.classList.replace('bg-green-700', 'bg-gold');
        }, 2000);
      }
    });
  </script>
</Base>
