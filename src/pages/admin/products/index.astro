---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/requireAdmin';
import { ssrClient } from '../../../lib/supabase';

const gate = await requireAdmin(Astro);
if (gate) return gate;

const sb = ssrClient(Astro.cookies);
const { data: products } = await sb
  .from('products')
  .select('id, slug, name, price_pence, inventory, published_at, image_url')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Products">
  <div style="margin-bottom:16px; display:flex; justify-content:flex-end;">
    <a href="/shop" target="_blank" style="font-size:13px; color:#C8A96E; text-decoration:none;">View shop ↗</a>
  </div>

  <div style="background:#1A1A1A; border:1px solid rgba(255,255,255,0.08); border-radius:6px; overflow:hidden;">
    <table style="width:100%; border-collapse:collapse; font-size:13px;">
      <thead>
        <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Product</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Price</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Stock</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Status</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {(products ?? []).map(p => (
          <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
            <td style="padding:12px 16px;">
              <div style="display:flex; align-items:center; gap:10px;">
                {p.image_url && <img src={p.image_url} alt={p.name} style="width:36px; height:36px; object-fit:cover; border-radius:3px; background:#242424;" loading="lazy"/>}
                <div>
                  <div style="font-weight:500; color:#F0EDE8;">{p.name}</div>
                  <div style="color:#9A9189; font-size:11px;">{p.slug}</div>
                </div>
              </div>
            </td>
            <td style="padding:12px 16px; color:#F0EDE8;">${(p.price_pence / 100).toFixed(2)}</td>
            <td style="padding:12px 16px; color:#9A9189;">{p.inventory ?? 0}</td>
            <td style="padding:12px 16px;">
              <span style={`font-size:11px; padding:2px 8px; border-radius:9999px; ${p.published_at ? 'background:rgba(74,222,128,0.1);color:#4ade80' : 'background:rgba(255,255,255,0.05);color:#9A9189'}`}>
                {p.published_at ? 'Live' : 'Draft'}
              </span>
            </td>
            <td style="padding:12px 16px;">
              <a href={`/admin/products/${p.id}`} style="font-size:12px; color:#C8A96E; text-decoration:none; margin-right:12px;">Edit</a>
              <a href={`/product/${p.slug}`} target="_blank" style="font-size:12px; color:#9A9189; text-decoration:none;">View ↗</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    {(!products || products.length === 0) && (
      <div style="text-align:center; padding:40px; color:#9A9189;">No products found</div>
    )}
  </div>
</AdminLayout>
