---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/requireAdmin';
import { ssrClient } from '../../lib/supabase';

const gate = await requireAdmin(Astro);
if (gate) return gate;

const sb = ssrClient(Astro.cookies);

const [products, orders, messages, subscribers] = await Promise.all([
  sb.from('products').select('id', { count: 'exact', head: true }),
  sb.from('orders').select('id', { count: 'exact', head: true }),
  sb.from('contact_messages').select('id', { count: 'exact', head: true }),
  sb.from('subscribers').select('id', { count: 'exact', head: true }),
]);
---

<AdminLayout title="Dashboard">
  <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px; margin-bottom:32px;">
    {[
      { label: 'Products', count: products.count ?? 0, href: '/admin/products', icon: '👕' },
      { label: 'Orders', count: orders.count ?? 0, href: '/admin/orders', icon: '📦' },
      { label: 'Messages', count: messages.count ?? 0, href: '/admin/messages', icon: '✉️' },
      { label: 'Subscribers', count: subscribers.count ?? 0, href: '/admin/subscribers', icon: '📧' },
    ].map(card => (
      <a href={card.href} style="background:#1A1A1A; border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:20px; text-decoration:none; display:block; transition:border-color 0.15s;"
        onmouseover="this.style.borderColor='rgba(200,169,110,0.4)'"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
        <div style="font-size:1.5rem; margin-bottom:8px;">{card.icon}</div>
        <div style="font-size:2rem; font-weight:700; color:#F0EDE8; margin-bottom:4px;">{card.count}</div>
        <div style="font-size:12px; color:#9A9189;">{card.label}</div>
      </a>
    ))}
  </div>

  <div style="background:#1A1A1A; border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:24px;">
    <h2 style="font-size:1rem; font-weight:600; margin:0 0 16px; color:#F0EDE8;">Quick actions</h2>
    <div style="display:flex; flex-wrap:wrap; gap:10px;">
      <a href="/admin/products" style="background:#C8A96E; color:#0F0F0F; padding:8px 16px; border-radius:4px; text-decoration:none; font-size:13px; font-weight:600;">Manage products</a>
      <a href="/admin/orders" style="border:1px solid rgba(255,255,255,0.2); color:#F0EDE8; padding:8px 16px; border-radius:4px; text-decoration:none; font-size:13px;">View orders</a>
      <a href="/admin/messages" style="border:1px solid rgba(255,255,255,0.2); color:#F0EDE8; padding:8px 16px; border-radius:4px; text-decoration:none; font-size:13px;">Read messages</a>
      <a href="/shop" target="_blank" style="border:1px solid rgba(255,255,255,0.2); color:#F0EDE8; padding:8px 16px; border-radius:4px; text-decoration:none; font-size:13px;">View storefront ↗</a>
    </div>
  </div>
</AdminLayout>
