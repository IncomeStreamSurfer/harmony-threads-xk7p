---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/requireAdmin';
import { ssrClient } from '../../lib/supabase';

const gate = await requireAdmin(Astro);
if (gate) return gate;

const sb = ssrClient(Astro.cookies);
const { data: categories } = await sb
  .from('categories')
  .select('*')
  .order('sort_order');
---

<AdminLayout title="Categories">
  <div style="background:#1A1A1A; border:1px solid rgba(255,255,255,0.08); border-radius:6px; overflow:hidden;">
    <table style="width:100%; border-collapse:collapse; font-size:13px;">
      <thead>
        <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Name</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Slug</th>
          <th style="text-align:left; padding:12px 16px; color:#9A9189; font-weight:500;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {(categories ?? []).map(c => (
          <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
            <td style="padding:12px 16px; color:#F0EDE8; font-weight:500;">{c.name}</td>
            <td style="padding:12px 16px; color:#9A9189; font-family:monospace; font-size:11px;">{c.slug}</td>
            <td style="padding:12px 16px;">
              <a href={`/collections/${c.slug}`} target="_blank" style="font-size:12px; color:#C8A96E; text-decoration:none;">View ↗</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
