---
import Base from '../layouts/Base.astro';

const renderedAt = Date.now();
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmony-threads-xk7p.vercel.app';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${siteUrl}/contact` }
  ]
};
---

<Base
  title="Contact Us | Harmony Threads"
  description="Get in touch with Harmony Threads. Questions about orders, sizing, digital downloads, or wholesale — we respond within 1 business day."
  structuredData={breadcrumb}
>
  <div class="pt-32 pb-20 max-w-7xl mx-auto px-6">

    <nav class="flex items-center gap-2 text-xs text-muted mb-16" style="font-family:'Manrope',system-ui,sans-serif;">
      <a href="/" class="hover:text-cream transition-colors">Home</a>
      <span>/</span>
      <span class="text-cream">Contact</span>
    </nav>

    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-4" style="font-family:'Manrope',system-ui,sans-serif;">Get in touch</p>
        <h1 class="text-5xl font-semibold text-cream leading-tight mb-6" style="font-family:'Playfair Display',Georgia,serif;">
          We read every message
        </h1>
        <p class="text-muted leading-relaxed mb-10" style="font-family:'Manrope',system-ui,sans-serif;">
          Order questions, sizing, digital downloads, wholesale enquiries — send us a note and we'll get back to you within 1 business day.
        </p>

        <div class="space-y-6">
          {[
            { icon: '📦', heading: 'Order support', copy: 'Something wrong with your order? We\'ll sort it out immediately.' },
            { icon: '📏', heading: 'Sizing help', copy: 'Unsure which size to pick? Tell us your measurements and we\'ll recommend the right fit.' },
            { icon: '⚡', heading: 'Digital downloads', copy: 'Didn\'t receive your download link? We\'ll resend it within the hour.' },
          ].map(i => (
            <div class="flex gap-4 items-start">
              <span class="text-2xl mt-0.5">{i.icon}</span>
              <div>
                <p class="text-cream font-medium mb-1" style="font-family:'Manrope',system-ui,sans-serif;">{i.heading}</p>
                <p class="text-muted text-sm" style="font-family:'Manrope',system-ui,sans-serif;">{i.copy}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <form id="contact-form" method="POST" action="/api/contact" class="space-y-5">
          <input type="hidden" name="renderedAt" value={renderedAt} />
          <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off"
            style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" />

          <div>
            <label for="name" class="block text-sm font-medium text-cream mb-2" style="font-family:'Manrope',system-ui,sans-serif;">Your name</label>
            <input
              type="text" id="name" name="name" required
              placeholder="Jane Smith"
              class="w-full bg-charcoal-2 border border-white/20 text-cream placeholder-muted text-sm px-4 py-3 rounded-sm focus:border-gold focus:outline-none transition-colors"
              style="font-family:'Manrope',system-ui,sans-serif;"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-cream mb-2" style="font-family:'Manrope',system-ui,sans-serif;">Email address</label>
            <input
              type="email" id="email" name="email" required
              placeholder="you@example.com"
              class="w-full bg-charcoal-2 border border-white/20 text-cream placeholder-muted text-sm px-4 py-3 rounded-sm focus:border-gold focus:outline-none transition-colors"
              style="font-family:'Manrope',system-ui,sans-serif;"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-cream mb-2" style="font-family:'Manrope',system-ui,sans-serif;">Message</label>
            <textarea
              id="message" name="message" required rows="5"
              placeholder="Tell us what's on your mind…"
              class="w-full bg-charcoal-2 border border-white/20 text-cream placeholder-muted text-sm px-4 py-3 rounded-sm focus:border-gold focus:outline-none transition-colors resize-none"
              style="font-family:'Manrope',system-ui,sans-serif;"
            ></textarea>
          </div>

          <button type="submit" id="contact-submit"
            class="w-full bg-gold text-charcoal font-semibold py-4 rounded-sm hover:bg-gold-light transition-colors text-sm"
            style="font-family:'Manrope',system-ui,sans-serif;">
            Send message
          </button>

          <div id="form-status" class="hidden"></div>
        </form>
      </div>
    </div>

    <!-- Internal links -->
    <div class="mt-16 pt-10 border-t border-white/10 flex flex-wrap gap-6">
      <a href="/shop" class="text-sm text-gold hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">Browse the shop →</a>
      <a href="/about" class="text-sm text-gold hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">Our story →</a>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('contact-submit') as HTMLButtonElement;
    const status = document.getElementById('form-status')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.textContent = 'Sending…';
      btn.disabled = true;

      const body = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const json = await res.json();
        if (json.ok) {
          form.reset();
          status.className = 'text-sm text-green-400 mt-2';
          status.textContent = '✓ Message sent — we\'ll reply within 1 business day.';
        } else {
          status.className = 'text-sm text-red-400 mt-2';
          status.textContent = json.error ?? 'Something went wrong. Please try again.';
          btn.textContent = 'Send message';
          btn.disabled = false;
        }
      } catch {
        status.className = 'text-sm text-red-400 mt-2';
        status.textContent = 'Network error — please try again.';
        btn.textContent = 'Send message';
        btn.disabled = false;
      }
    });
  </script>
</Base>
