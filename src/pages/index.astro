---
import Base from '../layouts/Base.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmony-threads-xk7p.vercel.app';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Harmony Threads",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "sameAs": []
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Harmony Threads",
  "url": siteUrl,
  "description": "Music-inspired graphic tees, digital downloads, and lifestyle goods for those who live the sound."
};

const products = [
  {
    title: 'The Band Graphic T-Shirt',
    desc: 'Celebrate the legacy of rock\'s most iconic group. Available in green, gray, and red.',
    price: '$19.99',
    compareAt: '$24.99',
    image: 'https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=800',
    href: '/product/physical-product-the-band-t-shirt',
    tag: 'Top Seller',
    type: 'physical',
  },
  {
    title: 'The History of Rock Music',
    desc: 'A deep dive into six decades of amplified rebellion. Available in PDF, Kindle, and Audio.',
    price: '$14.99',
    compareAt: null,
    image: 'https://picsum.photos/seed/rockbook/800/600',
    href: '/product/digital-product-the-history-of-rock-music',
    tag: 'Digital',
    type: 'digital',
  },
  {
    title: 'Signature Perfume',
    desc: 'A bold fragrance for those who carry the music with them. Premium, long-lasting.',
    price: '$74.99',
    compareAt: '$80.00',
    image: 'https://burst.shopifycdn.com/photos/black-glass-perfume-bottle-and-spritzer.jpg?width=800',
    href: '/product/example-perfume',
    tag: 'Lifestyle',
    type: 'physical',
  },
];
---

<Base
  title="Harmony Threads — Wear the Music You Love"
  description="Music-inspired graphic tees, digital downloads & lifestyle goods for rock fans. Free shipping over $50. Shop The Band t-shirt, rock history ebooks, and more."
  structuredData={[orgSchema, websiteSchema]}
>

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background texture -->
    <div class="absolute inset-0 bg-charcoal">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 70% 50%, #1a1208 0%, #0F0F0F 65%);"></div>
      <!-- Decorative lines -->
      <div class="absolute right-0 top-0 h-full w-px bg-white/5"></div>
      <div class="absolute right-16 top-0 h-full w-px bg-white/[0.03]"></div>
    </div>

    <!-- Large typographic accent -->
    <div class="absolute right-[-2rem] top-1/2 -translate-y-1/2 select-none pointer-events-none hidden lg:block"
      style="font-family:'Playfair Display',Georgia,serif; font-size: clamp(12rem, 20vw, 22rem); font-weight:700; color: rgba(200,169,110,0.04); line-height:1; letter-spacing:-0.05em;">
      ♪
    </div>

    <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20 grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: copy -->
      <div>
        <div class="inline-flex items-center gap-2 mb-8 px-3 py-1 border border-gold/30 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
          <span class="text-gold text-xs font-medium tracking-widest uppercase" style="font-family:'Manrope',system-ui,sans-serif;">New for 2026</span>
        </div>

        <h1 class="mb-6 text-cream leading-[1.02] tracking-tight"
          style="font-family:'Playfair Display',Georgia,serif; font-size: clamp(2.8rem, 6vw, 5.5rem); font-weight:600;">
          Wear the<br/>
          <em style="font-style:italic; color:#C8A96E;">Music</em><br/>
          You Love
        </h1>

        <p class="text-muted leading-relaxed mb-10 max-w-md text-lg" style="font-family:'Manrope',system-ui,sans-serif;">
          Graphic tees that carry the spirit of rock's legends. Digital histories that tell the full story. Goods for people who don't just listen — they live it.
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <a href="/shop"
            class="inline-flex items-center gap-2 bg-gold text-charcoal font-semibold px-7 py-3.5 rounded-sm hover:bg-gold-light transition-colors text-sm"
            style="font-family:'Manrope',system-ui,sans-serif;">
            Shop the Collection
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/collections/graphic-tees"
            class="inline-flex items-center gap-2 text-muted hover:text-cream transition-colors text-sm"
            style="font-family:'Manrope',system-ui,sans-serif;">
            Browse graphic tees →
          </a>
        </div>

        <!-- Social proof strip -->
        <div class="mt-14 pt-10 border-t border-white/10 flex items-center gap-8 flex-wrap">
          {[
            { n: '3 colors', l: 'per design' },
            { n: '4 sizes', l: 'XS to XL' },
            { n: '140+', l: 'orders in April' },
          ].map(s => (
            <div>
              <div class="text-2xl font-semibold text-cream" style="font-family:'Playfair Display',Georgia,serif;">{s.n}</div>
              <div class="text-xs text-muted mt-0.5" style="font-family:'Manrope',system-ui,sans-serif;">{s.l}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: hero product card -->
      <div class="relative">
        <div class="relative overflow-hidden rounded-sm aspect-[4/5] bg-charcoal-2">
          <img
            src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=900"
            alt="The Band graphic t-shirt in forest green — Harmony Threads"
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
          <!-- Overlay gradient -->
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,15,15,0.6) 0%, transparent 50%);"></div>
          <!-- Price tag -->
          <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between">
            <div>
              <p class="text-white text-lg font-semibold" style="font-family:'Playfair Display',Georgia,serif;">The Band T-Shirt</p>
              <p class="text-gold text-sm" style="font-family:'Manrope',system-ui,sans-serif;">$19.99 <span class="line-through text-muted/60 text-xs">$24.99</span></p>
            </div>
            <a href="/product/physical-product-the-band-t-shirt"
              class="bg-gold text-charcoal text-xs font-bold px-3 py-2 rounded-sm hover:bg-gold-light transition-colors"
              style="font-family:'Manrope',system-ui,sans-serif;">
              Buy Now
            </a>
          </div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -top-4 -right-4 bg-gold text-charcoal text-xs font-bold px-3 py-2 rounded-full shadow-lg"
          style="font-family:'Manrope',system-ui,sans-serif;">
          Top Seller ★
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee band -->
  <div class="border-y border-white/10 bg-charcoal-2 overflow-hidden py-4">
    <div class="flex gap-12 animate-[marquee_20s_linear_infinite] whitespace-nowrap">
      {Array(4).fill(['Free shipping over $50', 'Unisex sizing', 'Vintage graphic style', 'Digital downloads instant', 'New colors monthly', 'Rock heritage merch']).flat().map(t => (
        <span class="text-xs text-muted tracking-widest uppercase font-medium flex-shrink-0" style="font-family:'Manrope',system-ui,sans-serif;">
          ♪ &nbsp; {t}
        </span>
      ))}
    </div>
  </div>

  <!-- Featured products -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="flex items-end justify-between mb-14">
      <div>
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3" style="font-family:'Manrope',system-ui,sans-serif;">The Collection</p>
        <h2 class="text-4xl font-semibold text-cream leading-tight" style="font-family:'Playfair Display',Georgia,serif;">
          Everything in the shop
        </h2>
      </div>
      <a href="/shop" class="hidden md:flex items-center gap-2 text-gold text-sm hover:text-gold-light transition-colors" style="font-family:'Manrope',system-ui,sans-serif;">
        View all products →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {products.map(p => (
        <article class="group">
          <a href={p.href} class="block">
            <div class="overflow-hidden rounded-sm aspect-[3/4] bg-charcoal-2 mb-5 relative">
              <img
                src={p.image}
                alt={p.title + ' — Harmony Threads'}
                class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-charcoal/80 backdrop-blur-sm text-gold text-xs font-medium px-2.5 py-1 rounded-full border border-gold/30" style="font-family:'Manrope',system-ui,sans-serif;">
                  {p.tag}
                </span>
              </div>
            </div>
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-cream font-medium mb-1 leading-snug" style="font-family:'Playfair Display',Georgia,serif; font-size:1.1rem;">{p.title}</h3>
                <p class="text-muted text-sm leading-relaxed line-clamp-2" style="font-family:'Manrope',system-ui,sans-serif;">{p.desc}</p>
              </div>
            </div>
            <div class="flex items-center gap-2 mt-3">
              <span class="text-cream font-semibold" style="font-family:'Manrope',system-ui,sans-serif;">{p.price}</span>
              {p.compareAt && <span class="text-muted text-sm line-through" style="font-family:'Manrope',system-ui,sans-serif;">{p.compareAt}</span>}
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-10 md:hidden text-center">
      <a href="/shop" class="inline-flex items-center gap-2 text-gold text-sm" style="font-family:'Manrope',system-ui,sans-serif;">View all products →</a>
    </div>
  </section>

  <!-- Divider section — graphic tees highlight -->
  <section class="bg-charcoal-2 border-y border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-3">
          {[
            { color: 'Green', hex: '#4A6741', img: 'https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=500' },
            { color: 'Gray', hex: '#6B6B6B', img: 'https://picsum.photos/seed/graytee/500/600' },
          ].map(c => (
            <div class="aspect-square overflow-hidden rounded-sm bg-charcoal-3 relative">
              <img src={c.img} alt={`The Band t-shirt in ${c.color}`} class="w-full h-full object-cover" loading="lazy"/>
              <div class="absolute bottom-2 left-2 bg-charcoal/80 backdrop-blur-sm text-cream text-xs px-2 py-1 rounded-full" style="font-family:'Manrope',system-ui,sans-serif;">{c.color}</div>
            </div>
          ))}
          <div class="col-span-2 aspect-[2/1] overflow-hidden rounded-sm bg-charcoal-3">
            <img src="https://picsum.photos/seed/bandtee3/800/400" alt="Red Band t-shirt lifestyle shot" class="w-full h-full object-cover" loading="lazy"/>
          </div>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-4" style="font-family:'Manrope',system-ui,sans-serif;">Graphic Tees</p>
        <h2 class="text-4xl font-semibold text-cream leading-tight mb-6" style="font-family:'Playfair Display',Georgia,serif;">
          Three colors.<br/>One enduring legacy.
        </h2>
        <p class="text-muted leading-relaxed mb-8" style="font-family:'Manrope',system-ui,sans-serif;">
          The Band T-Shirt comes in forest green, charcoal gray, and bold red. Unisex sizing from Small to XL, 150g ring-spun cotton that softens with every wash.
        </p>
        <div class="flex flex-col gap-3 mb-8">
          {[
            'Unisex sizing — Small through XL',
            '150g ring-spun cotton',
            'Graphic holds up through 100+ washes',
            'Was $24.99 — now $19.99',
          ].map(f => (
            <div class="flex items-center gap-3" style="font-family:'Manrope',system-ui,sans-serif;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="flex-shrink-0">
                <path d="M3 8l3.5 3.5L13 4" stroke="#C8A96E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-sm text-muted">{f}</span>
            </div>
          ))}
        </div>
        <a href="/collections/graphic-tees"
          class="inline-flex items-center gap-2 bg-gold text-charcoal font-semibold px-6 py-3 rounded-sm hover:bg-gold-light transition-colors text-sm"
          style="font-family:'Manrope',system-ui,sans-serif;">
          See all graphic tees →
        </a>
      </div>
    </div>
  </section>

  <!-- Digital section -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-3">
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-4" style="font-family:'Manrope',system-ui,sans-serif;">Digital Downloads</p>
        <h2 class="text-4xl font-semibold text-cream leading-tight mb-6" style="font-family:'Playfair Display',Georgia,serif;">
          The full story of rock — yours instantly
        </h2>
        <p class="text-muted leading-relaxed mb-8 max-w-xl" style="font-family:'Manrope',system-ui,sans-serif;">
          From Chuck Berry's first riff to stadium anthems, <em>The History of Rock Music</em> covers six decades of amplified rebellion. Available as PDF, Kindle, or Audiobook — no waiting, no shipping.
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          {['PDF', 'Kindle / ePub', 'Audiobook'].map(f => (
            <span class="border border-gold/30 text-gold text-xs px-3 py-1.5 rounded-full" style="font-family:'Manrope',system-ui,sans-serif;">{f}</span>
          ))}
        </div>
        <a href="/product/digital-product-the-history-of-rock-music"
          class="inline-flex items-center gap-2 border border-gold/40 text-gold font-medium px-6 py-3 rounded-sm hover:bg-gold/10 transition-colors text-sm"
          style="font-family:'Manrope',system-ui,sans-serif;">
          Get instant access — $14.99 →
        </a>
      </div>
      <div class="lg:col-span-2">
        <div class="relative aspect-[3/4] bg-charcoal-2 rounded-sm overflow-hidden">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
            <div class="text-8xl mb-4">🎸</div>
            <p class="text-2xl font-semibold text-cream mb-2" style="font-family:'Playfair Display',Georgia,serif;">The History<br/>of Rock Music</p>
            <p class="text-muted text-sm" style="font-family:'Manrope',system-ui,sans-serif;">by Harmony Publishing</p>
            <div class="mt-6 flex gap-2 flex-wrap justify-center">
              <span class="bg-gold/20 text-gold text-xs px-2 py-1 rounded border border-gold/30">PDF</span>
              <span class="bg-gold/20 text-gold text-xs px-2 py-1 rounded border border-gold/30">Kindle</span>
              <span class="bg-gold/20 text-gold text-xs px-2 py-1 rounded border border-gold/30">Audio</span>
            </div>
            <p class="mt-6 text-3xl font-semibold text-cream" style="font-family:'Playfair Display',Georgia,serif;">$14.99</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ / trust -->
  <section class="bg-charcoal-2 border-t border-white/10">
    <div class="max-w-4xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-semibold text-cream mb-12 text-center" style="font-family:'Playfair Display',Georgia,serif;">
        Questions you probably have
      </h2>
      <div class="space-y-6">
        {[
          { q: 'How does shipping work?', a: 'We ship all physical orders within 2 business days. Free shipping on orders over $50 in the US. International rates calculated at checkout.' },
          { q: 'What sizes do the t-shirts come in?', a: 'Our graphic tees are unisex and come in Small, Medium, Large, and XL. They run true to size — check the size guide on each product page.' },
          { q: 'How do I access my digital purchase?', a: 'Digital orders are delivered instantly to your email. You\'ll receive a download link valid for 30 days. PDFs, Kindle files, and audio files are included in one package.' },
          { q: 'What\'s your return policy?', a: 'Physical items can be returned within 30 days if unworn and in original condition. Digital purchases are non-refundable once downloaded — contact us if you have any issues.' },
        ].map(faq => (
          <details class="group border-b border-white/10 pb-6">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <span class="text-cream font-medium" style="font-family:'Manrope',system-ui,sans-serif;">{faq.q}</span>
              <svg class="text-gold flex-shrink-0 transition-transform group-open:rotate-45" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </summary>
            <p class="mt-4 text-muted text-sm leading-relaxed" style="font-family:'Manrope',system-ui,sans-serif;">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="border border-white/10 rounded-sm p-10 md:p-16 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3" style="font-family:'Manrope',system-ui,sans-serif;">Stay in tune</p>
        <h2 class="text-3xl font-semibold text-cream" style="font-family:'Playfair Display',Georgia,serif;">New drops, first access.</h2>
        <p class="text-muted text-sm mt-2" style="font-family:'Manrope',system-ui,sans-serif;">Join 1,200+ music fans who get early access to new designs and digital releases.</p>
      </div>
      <form action="/api/subscribe" method="POST" class="flex gap-3 w-full md:w-auto">
        <input type="hidden" name="_honey" value="" style="display:none;"/>
        <input type="hidden" name="_ts" id="form-ts"/>
        <input
          type="email"
          name="email"
          required
          placeholder="Your email address"
          class="flex-1 md:w-64 bg-charcoal-2 border border-white/20 text-cream placeholder-muted text-sm px-4 py-3 rounded-sm focus:border-gold focus:outline-none transition-colors"
          style="font-family:'Manrope',system-ui,sans-serif;"
        />
        <button type="submit"
          class="bg-gold text-charcoal font-semibold px-5 py-3 rounded-sm hover:bg-gold-light transition-colors text-sm flex-shrink-0"
          style="font-family:'Manrope',system-ui,sans-serif;">
          Join the list
        </button>
      </form>
    </div>
  </section>

  <style>
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
  </style>

  <script>
    (document.getElementById('form-ts') as HTMLInputElement).value = Date.now().toString();
  </script>

</Base>
